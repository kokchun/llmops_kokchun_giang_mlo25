    "from typing import Optional, Literal\n",
    "\n",
    "\n",
    "class EmailExtractor(BaseModel):\n",
    "    sender_name: Optional[str]\n",
    "    sender_email: EmailStr\n",
    "    issue_category: Literal[\"billing\", \"damaged product\", \"technical\", \"other\"]"
   ]
